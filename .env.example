# Notion 내부 통합(internal integration) Secret. notion.so/my-integrations 에서 발급.
NOTION_API_KEY=

# 리크루팅 지원서를 저장할 Notion 데이터베이스 ID.
# scripts/create-notion-database.ts 실행 결과로 얻는다.
NOTION_DATABASE_ID=

# scripts/create-notion-database.ts 실행 시에만 사용 — 새 데이터베이스를 생성할
# 부모 페이지 ID. 앱 런타임에는 필요하지 않다.
NOTION_PARENT_PAGE_ID=

# 마감 화면 "알림 신청하기" 이메일을 저장할 Notion 데이터베이스 ID.
# scripts/create-notion-notify-database.ts 실행 결과로 얻는다.
NOTION_NOTIFY_DATABASE_ID=

NEXT_PUBLIC_GA_MEASUREMENT_ID=

# (선택) 지원서 제출 알림을 보낼 Discord 웹훅 URL.
# 채널 설정 → 연동 → 웹훅에서 발급. 미설정이면 알림만 생략된다.
DISCORD_SUBMIT_WEBHOOK_URL=

# (선택) 부정 접근 시도 알림을 보낼 Discord 웹훅 URL.
DISCORD_ABUSE_WEBHOOK_URL=

# Vercel Blob 스토어 Read/Write 토큰. Vercel 대시보드 → Storage → Blob 스토어를
# 프로젝트에 연결하면 배포 환경에는 자동 주입된다. 로컬은 `vercel env pull` 또는 수동 복사.
BLOB_READ_WRITE_TOKEN=
