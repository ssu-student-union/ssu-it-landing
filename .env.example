# Notion 내부 통합(internal integration) Secret. notion.so/my-integrations 에서 발급.
NOTION_API_KEY=

# 리크루팅 지원서를 저장할 Notion 데이터베이스 ID.
# scripts/create-notion-database.ts 실행 결과로 얻는다.
NOTION_DATABASE_ID=

# scripts/create-notion-database.ts 실행 시에만 사용 — 새 데이터베이스를 생성할
# 부모 페이지 ID. 앱 런타임에는 필요하지 않다.
NOTION_PARENT_PAGE_ID=

NEXT_PUBLIC_GA_MEASUREMENT_ID=